PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Only needed if you run frontend and backend as two separate origins
# (e.g. two terminals in local dev without using the Vite proxy). Not needed
# on Render — the single-service deploy serves both from the same origin.
# CLIENT_URL=http://localhost:5173

# Render Postgres URL (auto-set by render.yaml on Render, leave blank for local SQLite)
# DATABASE_URL=postgres://user:pass@host/dbname

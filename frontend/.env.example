# Optional. Without these, the app uses relative paths (/api, same-origin
# sockets), which work both in production (single Render service) and in
# dev (Vite proxies /api and /socket.io to localhost:5000 — see vite.config.js).
# Only set these if you're running the frontend against a backend on a
# different host/port than the proxy expects.
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
